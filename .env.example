# ── KunTips frontend environment variables ──────────────────────────────────
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and must never be committed.

# URL of the deployed KunTips backend Worker (no trailing slash).
# Local dev: http://localhost:8787
# Production: https://kuntips-backend.<your-subdomain>.workers.dev
VITE_API_BASE_URL=https://kuntips-backend.your-subdomain.workers.dev

# Stripe publishable key (safe to expose to the browser).
# Test: starts with pk_test_
# Live: starts with pk_live_
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
